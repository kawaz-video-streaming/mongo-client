{
  "name": "@ido_kawaz/mongo-client",
  "version": "3.1.0",
  "description": "MongoDB client library for Kawaz Plus services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "clean:advanced": "rimraf dist node_modules package-lock.json",
    "build": "npm run clean && tsc",
    "build:watch": "tsc --watch",
    "build:advanced": "npm run clean:advanced && npm i && tsc",
    "test": "npm run build && jest --runInBand",
    "test:advanced": "npm run build:advanced && jest --runInBand",
    "package": "npm run test:advanced && npm publish --access public"
  },
  "keywords": [
    "mongodb",
    "database",
    "client"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "mongoose": "^9.2.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/ramda": "^0.31.1",
    "jest": "^30.0.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}